              <div class="hero-snowflake">❆</div>
              <div class="hero-snowflake">❄</div>
              <div class="hero-snowflake">❅</div>
            </div>
            <img src="https://montaz-serwis-klimatyzacji.pl/img/balwanek.webp" alt="Klimatyzator ścienny" width="600" height="336" fetchpriority="high" decoding="async" />
          </div>
        </div>
      </div>
      <div class="hero-badges">
        <div class="hero-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
