---
import Default from "@layouts/Default.astro";
import ServicesSection from "@components/ServicesSection.astro";
import OpinionsSection from "@components/OpinionsSection.astro";

const title = "Montaż Klimatyzacji Warszawa – Montaż i Serwis Klimatyzacji | Warszawa i okolice";
const description =
  "Zamontuj Klimat – Profesjonalny montaż i serwis klimatyzacji w Warszawie i okolicach. Gree, LG, Kaisai, Mitsubishi, Daikin. Do 7 lat gwarancji. Darmowa wycena.";
const keywords =
  "klimatyzacja Warszawa, montaż klimatyzacji, serwis klimatyzacji, Gree, LG, Kaisai, Mitsubishi, Daikin, klimatyzator";
const canonical = "https://montaz-serwis-klimatyzacji.pl";
---

<Default
  title={title}
  description={description}
  keywords={keywords}
  canonical={canonical}
>
  <Fragment slot="head">
    <meta property="og:title" content="Montaż Klimatyzacji Warszawa - Montaż i Serwis Klimatyzacji" />
    <meta property="og:description" content="Profesjonalny montaż klimatyzacji w Warszawie. 5 marek premium, do 7 lat gwarancji, darmowa wycena." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <link rel="preload" href="https://montaz-serwis-klimatyzacji.pl/img/balwanek.webp" as="image" />
    <style>
      .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: end;
      }
      .contact-info a {
        text-decoration: none;
        color: inherit;
      }
      .contact-info a:hover {
        color: #1a73e8;
      }
      .contact-map iframe {
        width: 100%;
        height: 420px;
        border: 0;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      }
      @media (max-width: 768px) {
        .contact-grid {
          grid-template-columns: 1fr;
        }
        .contact-map iframe {
          height: 300px;
        }
      }
    </style>
  </Fragment>

  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://montaz-serwis-klimatyzacji.pl#localbusiness",
      "additionalType": "https://schema.org/HVACBusiness",
      "name": "Zamontuj Klimat – Montaż i Serwis Klimatyzacji",
      "description": "Profesjonalny montaż, serwis i sprzedaż klimatyzacji w Warszawie i okolicach. Klimatyzatory Gree, LG, Kaisai, Mitsubishi, Daikin.",
      "url": "https://montaz-serwis-klimatyzacji.pl",
      "telephone": "+48 888 806 921",
      "email": "mskplxk@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Warszawa",
        "addressCountry": "PL"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 52.2297,
        "longitude": 21.0122
      },
      "areaServed": [
        { "@type": "City", "name": "Warszawa" },
        { "@type": "City", "name": "Piaseczno" },
        { "@type": "City", "name": "Pruszków" },
        { "@type": "City", "name": "Grodzisk Mazowiecki" },
        { "@type": "City", "name": "Legionowo" },
        { "@type": "City", "name": "Wołomin" },
        { "@type": "City", "name": "Otwock" },
        { "@type": "City", "name": "Marki" },
        { "@type": "City", "name": "Ząbki" },
        { "@type": "City", "name": "Józefów" }
      ],
      "openingHours": ["Mo-Fr 08:00-18:00", "Sa 09:00-14:00"],
      "makesOffer": [
        {
          "@type": "Offer",
          "itemOffered": { "@type": "Service", "name": "Montaż klimatyzacji" }
        },
        {
          "@type": "Offer",
          "itemOffered": { "@type": "Service", "name": "Serwis klimatyzacji" }
        },
        {
          "@type": "Offer",
          "itemOffered": { "@type": "Service", "name": "Sprzedaż klimatyzatorów" }
        }
      ]
    }
  </script>

  <!-- HERO -->
  <section class="hero">
